        <mxCell id="inputs-icon" value="Module inputs" style="image;aspect=fixed;whiteSpace=wrap;html=1;align=center;verticalLabelPosition=bottom;verticalAlign=top;image=img/lib/azure2/general/All_Resources.svg;" vertex="1" parent="1">
          <mxGeometry x="140" y="220" width="100" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="inputs-box" value="variables.tf&#xa;&#xa;- name (3-24 chars, lowercase, globally unique)&#xa;- resource_group_name&#xa;- location (default: germanywestcentral)&#xa;- tags = map(string)&#xa;- account_tier = Standard&#xa;- account_replication_type = LRS default&#xa;- access_tier = Hot default&#xa;- min_tls_version = TLS1_2&#xa;- https_traffic_only_enabled = true&#xa;- allow_nested_items_to_be_public = false" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9db;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="350" width="240" height="360" as="geometry"/>
        </mxCell>
        <mxCell id="legend-box" value="Legend&#xa;&#xa;Solid arrows = deployment flow&#xa;Dashed arrows = values passed or returned&#xa;Azure icons = verified Azure2 catalog paths&#xa;All mxCell ids are explicitly set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=12;align=left;spacingLeft=12;spacingTop=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="70" y="740" width="240" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="example-box" value="examples/simple/main.tf&#xa;&#xa;provider &quot;azurerm&quot; { features {} }&#xa;&#xa;resource &quot;azurerm_resource_group&quot; &quot;rg&quot; {&#xa;  name     = &quot;rg-learning-lab&quot;&#xa;  location = &quot;westeurope&quot;&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf3ff;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="240" width="460" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="module-box" value="module &quot;storage&quot; {&#xa;  source              = &quot;../../&quot;&#xa;  name                = &quot;stlabdevjohn001&quot;&#xa;  resource_group_name = azurerm_resource_group.rg.name&#xa;  location            = azurerm_resource_group.rg.location&#xa;  tags = { env = &quot;example&quot; }&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=13;align=left;spacingLeft=12;spacingTop=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="430" y="500" width="460" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="module-note" value="Module internals from modules/azure-storage-account/main.tf&#xa;create a single azurerm_storage_account.this resource using validated inputs and secure defaults." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;align=center;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="450" y="750" width="420" height="80" as="geometry"/>
