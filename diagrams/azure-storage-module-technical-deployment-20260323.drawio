        <mxCell id="azure-storage-note" value="main.tf resource settings&#xa;&#xa;- name = var.name&#xa;- resource_group_name = var.resource_group_name&#xa;- location = var.location&#xa;- account_tier = Standard default&#xa;- account_replication_type = LRS default&#xa;- access_tier = Hot default&#xa;- HTTPS only enabled&#xa;- min TLS = TLS1_2&#xa;- nested public access disabled&#xa;- tags = var.tags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#edf7ed;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;spacingTop=10;strokeWidth=2;" vertex="1" parent="1">
