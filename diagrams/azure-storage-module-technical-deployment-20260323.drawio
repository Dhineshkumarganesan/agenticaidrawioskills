        <mxCell id="azure-rg-note" value="Example root configuration provisions the resource group first, then passes its name and location into the module call." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#edf7ed;strokeColor=#82b366;fontSize=12;align=center;spacingTop=10;" vertex="1" parent="1">
